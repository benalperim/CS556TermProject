    "ejs-locals": "1.0.2",
    "errorhandler": "1.5.2",
    "express": "5.2.1",
    "express-fileupload": "0.0.5",
    "express-session": "^1.19.0",
    "file-type": "^22.0.1",
    "hbs": "^4.0.4",
    "humanize-ms": "1.0.1",
    "jquery": "^2.2.4",
    "lodash": "4.18.1",
    "marked": "18.0.5",
    "method-override": "latest",
    "moment": "2.30.1",
